{
  "permissions": {
    "allow": [
      "bash(gh issue view *)",
      "bash(gh pr view *)"
    ],
    "deny": [
      "read(~/.gnupg/**)",
      "Bash(brew uninstall *)",
      "Bash(brew remove *)",
      "Bash(brew autoremove *)",
      "Bash(brew cleanup *)"
    ],
    "denywrite": [
      "~/.ssh",
      "~/.aws",
      "~/.gnupg",
      "~/.gitconfig",
      "~/.git-credentials",
      "~/.npmrc"
      ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "denyRead": ["~/.gnupg/private-keys-v1.d", "~/.gnupg/secring.gpg"]
    }
  },
  "enabledPlugins": {
    "planning-with-files@planning-with-files": true
  },
  "alwaysThinkingEnabled": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"$HOME/.claude/hooks/gsd-statusline.js\""
  }
}